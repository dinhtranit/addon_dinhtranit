<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_expense_home" name="DT Expense Home"><t t-call="dt_core.portal_shell"><a href="/my/apps/expenses/new" class="dt-fab" aria-label="Thêm chi tiêu">+</a><section class="dt-section"><div class="dt-summary-grid"><div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="today_total_label"/></div><div class="dt-stat-card__label">Chi hôm nay • <t t-esc="today_count"/> khoản</div></div><div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="month_total_label"/></div><div class="dt-stat-card__label">Tổng tháng này</div></div></div><div class="dt-shortcuts"><a href="/my/apps/expenses/new" class="dt-app-card"><div class="dt-app-card__icon">➕</div><div class="dt-app-card__content"><div class="dt-app-card__name">Nhập khoản chi</div><div class="dt-app-card__desc">Ngày mặc định là hôm nay.</div></div></a><a href="/my/apps/expenses/reports" class="dt-app-card"><div class="dt-app-card__icon">📊</div><div class="dt-app-card__content"><div class="dt-app-card__name">Xem báo cáo</div><div class="dt-app-card__desc">Theo tuần, tháng, năm.</div></div></a><a href="/my/apps/expenses/categories" class="dt-app-card"><div class="dt-app-card__icon">🏷️</div><div class="dt-app-card__content"><div class="dt-app-card__name">Loại chi tiêu</div><div class="dt-app-card__desc"><t t-esc="category_count"/> loại đang có.</div></div></a><a href="/my/profile" class="dt-app-card"><div class="dt-app-card__icon">👤</div><div class="dt-app-card__content"><div class="dt-app-card__name">Trang cá nhân</div><div class="dt-app-card__desc">Sửa thông tin cá nhân.</div></div></a></div><div class="dt-report-block"><div class="dt-section-title">Khoản chi gần đây</div><div class="dt-list"><t t-if="recent_entries"><t t-foreach="recent_entries" t-as="entry"><div class="dt-entry-row"><div class="dt-entry-head"><div><div class="dt-entry-title"><t t-esc="entry.category_id.icon or '💸'"/> <t t-esc="entry.name or entry.category_id.name"/></div><div class="dt-entry-meta"><span class="dt-tag"><t t-esc="entry.expense_date.strftime('%d/%m/%Y') if entry.expense_date else ''"/></span><span class="dt-tag">#<t t-esc="entry.code"/></span><span class="dt-tag" t-if="entry.media_count">📎 <t t-esc="entry.media_count"/></span></div></div><div class="dt-entry-title"><t t-esc="'%.0f' % entry.amount"/> <t t-esc="entry.currency_id.symbol or entry.currency_id.name or ''"/></div></div><div t-if="entry.note" class="dt-entry-note"><t t-esc="entry.note"/></div><div class="dt-top-actions"><a t-att-href="'/my/apps/expenses/%s/edit' % entry.id" class="dt-btn dt-btn--secondary">Sửa</a><form t-att-action="'/my/apps/expenses/%s/delete' % entry.id" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><button type="submit" class="dt-btn dt-btn--ghost">Xóa</button></form></div></div></t></t><t t-else=""><div class="dt-empty-state"><div class="dt-section-title">Chưa có khoản chi nào</div><div class="dt-text-muted">Bắt đầu bằng nút cộng để nhập khoản chi đầu tiên.</div></div></t></div></div><t t-if="pager and pager.get('page_count', 0) &gt; 1"><div class="o_portal_pager"><t t-call="portal.portal_pager"/></div></t></section></t></template>
    <template id="portal_expense_form" name="DT Expense Form"><t t-call="dt_core.portal_shell"><section class="dt-section"><form action="/my/apps/expenses/save" method="post" enctype="multipart/form-data" class="dt-form dt-card p-3"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input t-if="entry" type="hidden" name="entry_id" t-att-value="entry.id"/><label class="dt-field"><span>Ngày chi</span><input type="date" name="expense_date" t-att-value="default_date"/></label><label class="dt-field"><span>Loại chi tiêu</span><select name="category_id" required="required"><option value="">Chọn loại chi</option><t t-foreach="categories" t-as="cat"><option t-att-value="cat.id" t-att-selected="'selected' if entry and entry.category_id.id == cat.id else None"><t t-esc="cat.icon or '💸'"/> <t t-esc="cat.name"/></option></t></select></label><label class="dt-field"><span>Số tiền</span><input type="number" step="0.01" min="0" name="amount" t-att-value="entry.amount if entry else ''" placeholder="0" required="required"/></label><label class="dt-field"><span>Tiêu đề ngắn</span><input type="text" name="name" t-att-value="entry.name if entry else ''" placeholder="Ví dụ: Đi chợ chiều, mua sách cho bé"/></label><label class="dt-field"><span>Ghi chú</span><textarea name="note" rows="4" placeholder="Ghi lại nội dung chi tiêu hoặc lưu ý thêm..."><t t-esc="entry.note if entry else ''"/></textarea></label><label class="dt-field"><span>Hình ảnh / video</span><input type="file" name="media_files" multiple="multiple" accept="image/*,video/*"/><div class="dt-file-help">Có thể đính kèm nhiều hình hóa đơn, video hoặc chứng từ cùng lúc.</div></label><button type="submit" class="dt-btn dt-btn--primary">Lưu khoản chi</button></form><t t-if="entry and entry.get_media_items()"><div class="dt-card"><div class="dt-section-title">Media hiện có</div><div class="dt-media-grid"><t t-foreach="entry.get_media_items()" t-as="media"><div class="dt-media-tile"><t t-if="media.media_type == 'image'"><img t-att-src="media.image_url()" alt="receipt"/></t><t t-else=""><video playsinline="playsinline" preload="metadata"><source t-att-src="media.stream_url()" t-att-type="media.mimetype or 'video/mp4'"/></video></t><form t-att-action="'/my/apps/expenses/media/%s/delete' % media.id" method="post" class="position-absolute" style="top:8px;right:8px;"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="entry_id" t-att-value="entry.id"/><button type="submit" class="dt-btn dt-btn--ghost" style="padding:6px 10px;">✕</button></form></div></t></div></div></t></section></t></template>
    <template id="portal_expense_categories" name="DT Expense Categories"><t t-call="dt_core.portal_shell"><section class="dt-section"><form action="/my/apps/expenses/categories/save" method="post" class="dt-form dt-card p-3"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><label class="dt-field"><span>Tên loại chi tiêu</span><input type="text" name="name" placeholder="Ví dụ: Ăn uống, Học hành, Con cái..." required="required"/></label><label class="dt-field"><span>Icon</span><input type="text" name="icon" value="💸" placeholder="Ví dụ: 🍜, 📚, 🧒"/></label><label class="dt-field"><span>Thứ tự</span><input type="number" name="sequence" value="10"/></label><label class="dt-field"><span>Ghi chú</span><input type="text" name="note" placeholder="Tùy chọn"/></label><button type="submit" class="dt-btn dt-btn--primary">Thêm loại chi</button></form><div class="dt-list"><t t-foreach="categories" t-as="cat"><div class="dt-category-row"><div class="dt-entry-head"><div><div class="dt-entry-title"><t t-esc="cat.icon or '💸'"/> <t t-esc="cat.name"/></div><div class="dt-entry-meta"><span class="dt-tag">#<t t-esc="cat.code"/></span><span class="dt-tag"><t t-esc="cat.entry_count"/> khoản chi</span><span t-if="cat.user_id" class="dt-tag">Riêng tôi</span><span t-if="not cat.user_id" class="dt-tag">Dùng chung</span></div></div></div><div t-if="cat.note" class="dt-entry-note"><t t-esc="cat.note"/></div></div></t></div></section></t></template>
    <template id="portal_expense_reports" name="DT Expense Reports"><t t-call="dt_core.portal_shell"><section class="dt-section"><form method="get" action="/my/apps/expenses/reports" class="dt-form dt-card p-3"><label class="dt-field"><span>Kiểu kỳ báo cáo</span><select name="period"><option value="week" t-att-selected="'selected' if period == 'week' else None">Tuần</option><option value="month" t-att-selected="'selected' if period == 'month' else None">Tháng</option><option value="year" t-att-selected="'selected' if period == 'year' else None">Năm</option></select></label><label class="dt-field"><span>Mốc ngày</span><input type="date" name="anchor_date" t-att-value="anchor_date"/></label><label class="dt-field"><span>Lọc theo loại</span><select name="category_id"><option value="">Tất cả</option><t t-foreach="categories" t-as="cat"><option t-att-value="cat.id" t-att-selected="'selected' if selected_category and selected_category.id == cat.id else None"><t t-esc="cat.icon or '💸'"/> <t t-esc="cat.name"/></option></t></select></label><button type="submit" class="dt-btn dt-btn--secondary">Xem báo cáo</button></form><div class="dt-summary-grid"><div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="total_label"/></div><div class="dt-stat-card__label">Tổng chi trong kỳ</div></div><div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="average_label"/></div><div class="dt-stat-card__label">Bình quân / khoản</div></div></div><div class="dt-report-block"><div class="dt-section-title">Theo loại chi tiêu</div><t t-if="category_bars"><t t-foreach="category_bars" t-as="row"><div class="dt-report-row"><div class="dt-entry-head"><div class="dt-entry-note"><t t-esc="row['label']"/></div><div class="dt-entry-note"><t t-esc="row['amount_label']"/></div></div><div class="dt-bar-track"><div class="dt-bar-fill" t-attf-style="width: #{row['ratio']}%;"></div></div></div></t></t><t t-else=""><div class="dt-empty-state">Chưa có dữ liệu cho bộ lọc này.</div></t></div><div class="dt-report-block"><div class="dt-section-title">Xu hướng theo thời gian</div><t t-if="trend_bars"><t t-foreach="trend_bars" t-as="row"><div class="dt-report-row"><div class="dt-entry-head"><div class="dt-entry-note"><t t-esc="row['label']"/></div><div class="dt-entry-note"><t t-esc="row['amount_label']"/></div></div><div class="dt-bar-track"><div class="dt-bar-fill" t-attf-style="width: #{row['ratio']}%;"></div></div></div></t></t></div><div class="dt-report-block"><div class="dt-section-title">Danh sách khoản chi</div><div class="dt-list"><t t-if="entries"><t t-foreach="entries" t-as="entry"><div class="dt-entry-row"><div class="dt-entry-head"><div><div class="dt-entry-title"><t t-esc="entry.category_id.icon or '💸'"/> <t t-esc="entry.name or entry.category_id.name"/></div><div class="dt-entry-meta"><span class="dt-tag"><t t-esc="entry.expense_date.strftime('%d/%m/%Y') if entry.expense_date else ''"/></span><span class="dt-tag">#<t t-esc="entry.code"/></span></div></div><div class="dt-entry-title"><t t-esc="'%.0f' % entry.amount"/> <t t-esc="entry.currency_id.symbol or entry.currency_id.name or ''"/></div></div><div t-if="entry.note" class="dt-entry-note"><t t-esc="entry.note"/></div></div></t></t><t t-else=""><div class="dt-empty-state">Không có khoản chi nào trong kỳ này.</div></t></div></div></section></t></template>
</odoo>
