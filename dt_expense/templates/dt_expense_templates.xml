<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_expense_home" name="Expense Home">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <form action="/my/apps/expenses/balance/save" method="post" class="dt-form dt-card p-3 d-none" data-balance-form="1">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <label class="dt-field">
                        <span>Số dư thực tế</span>
                        <input type="text" name="current_amount" t-att-value="current_balance_input" data-money-input="1" data-money-suggestions="1000,10000,100000,1000000"/>
                    </label>
                    <div class="dt-inline-actions">
                        <button type="submit" class="dt-btn dt-btn--primary">Lưu cập nhật</button>
                        <button type="button" class="dt-btn dt-btn--ghost" data-balance-cancel="1">Hủy</button>
                    </div>
                </form>

                <div class="dt-summary-grid">
                    <div class="dt-stat-card">
                        <div class="dt-balance-card" data-balance-card="1">
                            <div class="dt-stat-card__value dt-balance-value"><t t-esc="current_balance_label"/></div>
                            <div class="dt-stat-card__label">Số tiền hiện tại</div>
                        </div>
                    </div>
                    <div class="dt-stat-card">
                        <div class="dt-stat-card__value"><t t-esc="month_income_label"/></div>
                        <div class="dt-stat-card__label">Thu tháng này</div>
                    </div>
                    <div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="month_expense_label"/></div><div class="dt-stat-card__label">Chi tháng này</div></div>
                    <div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="month_net_label"/></div><div class="dt-stat-card__label">Ròng tháng này</div></div>
                </div>

                <div class="dt-shortcuts mt-1">
                    <a href="/my/apps/expenses/history" class="dt-app-card"><div class="dt-app-card__icon">📜</div><div class="dt-app-card__content"><div class="dt-app-card__name">Lịch sử giao dịch</div></div><div class="dt-app-card__arrow">›</div></a>
                    <a href="/my/apps/expenses/categories" class="dt-app-card"><div class="dt-app-card__icon">🗂️</div><div class="dt-app-card__content"><div class="dt-app-card__name">Danh mục</div></div><div class="dt-app-card__arrow">›</div></a>
                </div>

                <div class="dt-card p-3">
                    <div class="dt-entry-head"><div><div class="dt-section-title">Gần đây</div></div></div>
                    <div class="dt-list mt-3">
                        <t t-if="recent_entries">
                            <t t-foreach="recent_entries" t-as="entry">
                                <div class="dt-entry-row">
                                    <div class="dt-entry-head">
                                        <div>
                                            <div class="dt-entry-title"><t t-esc="entry.get_icon()"/> <t t-esc="entry.name or entry.category_id.name or entry.get_entry_type_label()"/></div>
                                            <div class="dt-entry-meta">
                                                <span class="dt-tag"><t t-esc="entry.expense_date.strftime('%d/%m/%Y') if entry.expense_date else ''"/></span>
                                                <span class="dt-tag" t-if="entry.category_id"><t t-esc="entry.category_id.name"/></span>
                                            </div>
                                        </div>
                                        <div t-attf-class="dt-entry-amount #{entry.amount_css_class}"><t t-esc="entry.amount_label"/></div>
                                    </div>
                                    <div class="dt-inline-actions mt-2">
                                        <a t-att-href="'/my/apps/expenses/%s/edit' % entry.id" class="dt-btn dt-btn--ghost">Sửa</a>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else=""><div class="dt-empty-state">Chưa có giao dịch nào.</div></t>
                    </div>
                </div>

                <a href="/my/apps/expenses/new" class="dt-fab" aria-label="Tạo giao dịch">+</a>
            </section>
        </t>
    </template>

    <template id="portal_expense_form" name="Expense Form">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <form t-att-action="'/my/apps/expenses/save'" method="post" enctype="multipart/form-data" class="dt-form dt-card p-3" data-expense-form="1">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input t-if="entry" type="hidden" name="entry_id" t-att-value="entry.id"/>
                    <input type="hidden" name="entry_type" t-att-value="active_tab" data-entry-type-hidden="1"/>

                    <div class="dt-tabbar" data-entry-tabbar="1">
                        <button type="button" t-attf-class="dt-tab #{'is-active' if active_tab == 'expense' else ''}" data-entry-tab="expense">Chi tiêu</button>
                        <button type="button" t-attf-class="dt-tab #{'is-active' if active_tab == 'income' else ''}" data-entry-tab="income">Thu nhập</button>
                        <button type="button" t-attf-class="dt-tab #{'is-active' if active_tab == 'adjustment' else ''}" data-entry-tab="adjustment">Điều chỉnh</button>
                    </div>

                    <label class="dt-field" data-category-field="1">
                        <span>Danh mục</span>
                        <select name="category_id" data-category-select="1">
                            <option value="">Chọn danh mục</option>
                            <t t-foreach="categories" t-as="cat">
                                <option t-att-value="cat.id" t-att-data-entry-type="cat.category_type" t-att-data-next-month-rule="'1' if cat.apply_next_month_rule else '0'" t-att-selected="'selected' if entry and entry.category_id and entry.category_id.id == cat.id else None"><t t-esc="cat.icon or '💸'"/> <t t-esc="cat.name"/></option>
                            </t>
                        </select>
                    </label>

                    <label class="dt-field">
                        <span>Tiêu đề</span>
                        <input type="text" name="name" t-att-value="entry.name if entry else ''" placeholder="Ví dụ: Ăn sáng bún riêu" data-title-input="1" autocomplete="off"/>
                        <div class="dt-autocomplete-list d-none" data-title-suggestion-list="1"></div>
                    </label>

                    <label class="dt-field">
                        <span>Số tiền</span>
                        <input type="text" name="amount" t-att-value="amount_input_value" data-money-input="1" data-money-suggestions="1000,10000,100000,1000000"/>
                    </label>

                    <div class="dt-grid-2">
                        <label class="dt-field">
                            <span>Ngày giao dịch</span>
                            <input type="date" name="expense_date" t-att-value="default_date" data-expense-date="1"/>
                        </label>
                        <label class="dt-field">
                            <span>Tháng hạch toán</span>
                            <input type="date" name="accounting_month" t-att-value="default_accounting_month" data-accounting-month="1"/>
                        </label>
                    </div>

                    <div class="dt-field d-none" data-adjustment-only="1">
                        <span>Hướng điều chỉnh</span>
                        <div class="dt-inline-check-grid">
                            <label class="dt-check-pill"><input type="radio" name="adjustment_direction" value="increase" t-att-checked="'checked' if not entry or entry.adjustment_direction == 'increase' else None"/> Tăng số dư</label>
                            <label class="dt-check-pill"><input type="radio" name="adjustment_direction" value="decrease" t-att-checked="'checked' if entry and entry.adjustment_direction == 'decrease' else None"/> Giảm số dư</label>
                        </div>
                    </div>

                    <label class="dt-field">
                        <span>Ghi chú</span>
                        <textarea name="note" rows="4" placeholder="Thêm ghi chú nếu cần"><t t-esc="entry.note if entry else ''"/></textarea>
                    </label>

                    <label class="dt-field">
                        <span>Ảnh / video đính kèm</span>
                        <input type="file" name="media_files" accept="image/*,video/*" multiple="multiple"/>
                    </label>

                    <div class="dt-inline-actions">
                        <button type="submit" class="dt-btn dt-btn--primary">Lưu giao dịch</button>
                        <a href="/my/apps/expenses/history" class="dt-btn dt-btn--ghost">Hủy</a>
                    </div>
                </form>
            </section>
        </t>
    </template>

    <template id="portal_expense_categories" name="Expense Categories">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <div class="dt-inline-actions">
                    <a href="/my/apps/expenses/categories/new?category_type=expense" class="dt-btn dt-btn--secondary">Tạo danh mục chi</a>
                    <a href="/my/apps/expenses/categories/new?category_type=income" class="dt-btn dt-btn--secondary">Tạo danh mục thu</a>
                </div>

                <div class="dt-card p-3">
                    <div class="dt-section-title">Danh mục chi tiêu</div>
                    <div class="dt-list mt-3">
                        <t t-if="roots_expense">
                            <t t-foreach="roots_expense" t-as="cat">
                                <t t-call="dt_expense.portal_expense_category_item"/>
                            </t>
                        </t>
                        <t t-else=""><div class="dt-empty-state">Chưa có danh mục chi tiêu.</div></t>
                    </div>
                </div>

                <div class="dt-card p-3">
                    <div class="dt-section-title">Danh mục thu nhập</div>
                    <div class="dt-list mt-3">
                        <t t-if="roots_income">
                            <t t-foreach="roots_income" t-as="cat">
                                <t t-call="dt_expense.portal_expense_category_item"/>
                            </t>
                        </t>
                        <t t-else=""><div class="dt-empty-state">Chưa có danh mục thu nhập.</div></t>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <template id="portal_expense_category_item" name="Expense Category Item">
        <div class="dt-category-row">
            <div class="dt-entry-head">
                <div>
                    <div class="dt-entry-title"><t t-esc="cat.icon or '💸'"/> <t t-esc="cat.name"/></div>
                    <div class="dt-entry-meta">
                        <span class="dt-tag"><t t-esc="cat.get_category_type_label()"/></span>
                        <span class="dt-tag"><t t-esc="cat.entry_count"/> giao dịch</span>
                        <span class="dt-tag"><t t-esc="cat.suggestion_count"/> gợi ý</span>
                        <span t-if="cat.apply_next_month_rule" class="dt-tag">Cuối tháng → tháng sau</span>
                    </div>
                </div>
                <details class="dt-more-menu">
                    <summary>⋮</summary>
                    <div class="dt-more-menu__panel">
                        <a t-att-href="'/my/apps/expenses/categories/%s/edit' % cat.id">Sửa</a>
                        <a t-att-href="'/my/apps/expenses/categories/%s/suggestions' % cat.id">Gợi ý tiêu đề</a>
                        <form t-att-action="'/my/apps/expenses/categories/%s/delete' % cat.id" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit">Xóa</button>
                        </form>
                    </div>
                </details>
            </div>
            <div t-if="cat.child_ids" class="dt-list mt-2">
                <t t-foreach="cat.child_ids" t-as="child">
                    <div class="dt-subcategory-row">
                        <div>
                            <div class="dt-entry-title"><t t-esc="child.icon or '•'"/> <t t-esc="child.name"/></div>
                            <div class="dt-entry-meta">
                                <span class="dt-tag"><t t-esc="child.entry_count"/> giao dịch</span>
                                <span class="dt-tag"><t t-esc="child.suggestion_count"/> gợi ý</span>
                            </div>
                        </div>
                        <details class="dt-more-menu">
                            <summary>⋮</summary>
                            <div class="dt-more-menu__panel">
                                <a t-att-href="'/my/apps/expenses/categories/%s/edit' % child.id">Sửa</a>
                                <a t-att-href="'/my/apps/expenses/categories/%s/suggestions' % child.id">Gợi ý tiêu đề</a>
                                <form t-att-action="'/my/apps/expenses/categories/%s/delete' % child.id" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button type="submit">Xóa</button>
                                </form>
                            </div>
                        </details>
                    </div>
                </t>
            </div>
        </div>
    </template>

    <template id="portal_expense_category_form" name="Expense Category Form">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <form action="/my/apps/expenses/categories/save" method="post" class="dt-form dt-card p-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input t-if="category" type="hidden" name="category_id" t-att-value="category.id"/>
                    <label class="dt-field">
                        <span>Loại giao dịch</span>
                        <select name="category_type">
                            <option value="expense" t-att-selected="'selected' if category_type == 'expense' else None">Chi tiêu</option>
                            <option value="income" t-att-selected="'selected' if category_type == 'income' else None">Thu nhập</option>
                        </select>
                    </label>
                    <label class="dt-field"><span>Tên danh mục</span><input type="text" name="name" t-att-value="category.name if category else ''" required="required"/></label>
                    <label class="dt-field"><span>Icon</span><input type="text" name="icon" t-att-value="category.icon if category else ('💰' if category_type == 'income' else '💸')"/></label>
                    <label class="dt-field">
                        <span>Danh mục cha</span>
                        <select name="parent_id">
                            <option value="">Không có</option>
                            <t t-foreach="parents" t-as="parent">
                                <option t-att-value="parent.id" t-att-selected="'selected' if category and category.parent_id and category.parent_id.id == parent.id else None"><t t-esc="parent.icon or '📁'"/> <t t-esc="parent.name"/></option>
                            </t>
                        </select>
                    </label>
                    <label class="dt-field"><span>Thứ tự</span><input type="number" name="sequence" t-att-value="category.sequence if category else 10"/></label>
                    <label class="dt-field"><span>Ghi chú</span><input type="text" name="note" t-att-value="category.note if category else ''"/></label>
                    <label class="dt-check-pill"><input type="checkbox" name="apply_next_month_rule" t-att-checked="'checked' if category and category.apply_next_month_rule else None"/> Cuối tháng tự gợi ý hạch toán sang tháng sau</label>
                    <div class="dt-inline-actions">
                        <button type="submit" class="dt-btn dt-btn--primary">Lưu danh mục</button>
                        <a href="/my/apps/expenses/categories" class="dt-btn dt-btn--ghost">Hủy</a>
                    </div>
                </form>
            </section>
        </t>
    </template>

    <template id="portal_expense_suggestions" name="Expense Suggestions">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <div class="dt-inline-actions"><a t-att-href="'/my/apps/expenses/categories/%s/suggestions/new' % category.id" class="dt-btn dt-btn--secondary">Thêm gợi ý</a></div>
                <div class="dt-card p-3">
                    <div class="dt-section-title">Danh mục: <t t-esc="category.name"/></div>
                    <div class="dt-list mt-3">
                        <t t-if="suggestions">
                            <t t-foreach="suggestions" t-as="suggestion">
                                <div class="dt-entry-row">
                                    <div class="dt-entry-head">
                                        <div>
                                            <div class="dt-entry-title"><t t-esc="suggestion.name"/></div>
                                            <div class="dt-entry-note">Thứ tự: <t t-esc="suggestion.sequence"/></div>
                                        </div>
                                        <details class="dt-more-menu">
                                            <summary>⋮</summary>
                                            <div class="dt-more-menu__panel">
                                                <a t-att-href="'/my/apps/expenses/suggestions/%s/edit' % suggestion.id">Sửa</a>
                                                <form t-att-action="'/my/apps/expenses/suggestions/%s/delete' % suggestion.id" method="post">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <button type="submit">Xóa</button>
                                                </form>
                                            </div>
                                        </details>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else=""><div class="dt-empty-state">Chưa có gợi ý tiêu đề nào.</div></t>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <template id="portal_expense_suggestion_form" name="Expense Suggestion Form">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <form t-att-action="'/my/apps/expenses/categories/%s/suggestions/save' % category.id" method="post" class="dt-form dt-card p-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input t-if="suggestion" type="hidden" name="suggestion_id" t-att-value="suggestion.id"/>
                    <label class="dt-field"><span>Tiêu đề gợi ý</span><input type="text" name="name" t-att-value="suggestion.name if suggestion else ''" required="required"/></label>
                    <label class="dt-field"><span>Thứ tự</span><input type="number" name="sequence" t-att-value="suggestion.sequence if suggestion else 10"/></label>
                    <div class="dt-inline-actions">
                        <button type="submit" class="dt-btn dt-btn--primary">Lưu gợi ý</button>
                        <a t-att-href="'/my/apps/expenses/categories/%s/suggestions' % category.id" class="dt-btn dt-btn--ghost">Hủy</a>
                    </div>
                </form>
            </section>
        </t>
    </template>

    <template id="portal_expense_history" name="Expense History">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <div class="dt-search-header dt-card p-3">
                    <form method="get" action="/my/apps/expenses/history" class="dt-search-inline">
                        <input type="hidden" name="tab" t-att-value="tab"/>
                        <input type="hidden" name="scope" t-att-value="scope"/>
                        <input t-if="member_id" type="hidden" name="member_id" t-att-value="member_id"/>
                        <input t-if="date_from" type="hidden" name="date_from" t-att-value="date_from"/>
                        <input t-if="date_to" type="hidden" name="date_to" t-att-value="date_to"/>
                        <input t-if="entry_type" type="hidden" name="entry_type" t-att-value="entry_type"/>
                        <input t-if="parent_id" type="hidden" name="parent_id" t-att-value="parent_id"/>
                        <input t-if="category_id" type="hidden" name="category_id" t-att-value="category_id"/>
                        <input t-if="group_mode" type="hidden" name="group_mode" t-att-value="group_mode"/>
                        <input type="search" name="search" t-att-value="search" placeholder="Tìm tiêu đề, ghi chú, danh mục, thành viên..."/>
                        <button type="button" class="dt-filter-btn" data-filter-toggle="1">⚙<t t-if="filter_count"> <span class="dt-filter-badge"><t t-esc="filter_count"/></span></t></button>
                    </form>
                </div>

                <form method="get" action="/my/apps/expenses/history" t-attf-class="dt-form dt-card p-3 #{'' if filter_count else 'd-none'}" data-filter-panel="1">
                    <input type="hidden" name="tab" t-att-value="tab"/>
                    <label class="dt-field"><span>Phạm vi</span><select name="scope"><option value="mine" t-att-selected="'selected' if scope == 'mine' else None">Của tôi</option><option value="family" t-att-selected="'selected' if scope == 'family' else None">Gia đình</option></select></label>
                    <label t-if="scope == 'family'" class="dt-field"><span>Thành viên</span><select name="member_id"><option value="">Tất cả thành viên</option><t t-foreach="family_members" t-as="member"><option t-att-value="member.id" t-att-selected="'selected' if member_id == member.id else None"><t t-esc="member.name"/></option></t></select></label>
                    <div class="dt-grid-2"><label class="dt-field"><span>Từ ngày</span><input type="date" name="date_from" t-att-value="date_from"/></label><label class="dt-field"><span>Đến ngày</span><input type="date" name="date_to" t-att-value="date_to"/></label></div>
                    <label class="dt-field"><span>Loại giao dịch</span><select name="entry_type"><option value="">Tất cả</option><option value="expense" t-att-selected="'selected' if entry_type == 'expense' else None">Chi tiêu</option><option value="income" t-att-selected="'selected' if entry_type == 'income' else None">Thu nhập</option><option value="adjustment" t-att-selected="'selected' if entry_type == 'adjustment' else None">Điều chỉnh</option></select></label>
                    <label class="dt-field"><span>Danh mục cha</span><select name="parent_id"><option value="">Tất cả</option><t t-foreach="parent_categories" t-as="cat"><option t-att-value="cat.id" t-att-selected="'selected' if parent_id == cat.id else None"><t t-esc="cat.name"/></option></t></select></label>
                    <label class="dt-field"><span>Danh mục con</span><select name="category_id"><option value="">Tất cả</option><t t-foreach="child_categories" t-as="cat"><option t-att-value="cat.id" t-att-selected="'selected' if category_id == cat.id else None"><t t-esc="cat.name"/></option></t></select></label>
                    <t t-if="tab == 'statistics'"><label class="dt-field"><span>Nhóm thống kê</span><select name="group_mode"><option value="parent" t-att-selected="'selected' if group_mode == 'parent' else None">Theo danh mục cha</option><option value="child" t-att-selected="'selected' if group_mode == 'child' else None">Theo danh mục con</option></select></label></t>
                    <div class="dt-inline-actions"><button type="submit" class="dt-btn dt-btn--primary">Áp dụng</button><a t-att-href="'/my/apps/expenses/history?tab=%s' % tab" class="dt-btn dt-btn--ghost">Xóa bộ lọc</a></div>
                </form>

                <div class="dt-tabbar">
                    <a t-attf-href="/my/apps/expenses/history?tab=activity&amp;scope=#{scope}" t-attf-class="dt-tab #{'is-active' if tab == 'activity' else ''}">Hoạt động</a>
                    <a t-attf-href="/my/apps/expenses/history?tab=statistics&amp;scope=#{scope}" t-attf-class="dt-tab #{'is-active' if tab == 'statistics' else ''}">Thống kê</a>
                </div>

                <div class="dt-summary-grid">
                    <div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="total_income_label"/></div><div class="dt-stat-card__label">Tổng thu</div></div>
                    <div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="total_expense_label"/></div><div class="dt-stat-card__label">Tổng chi</div></div>
                    <div class="dt-stat-card"><div class="dt-stat-card__value"><t t-esc="total_net_label"/></div><div class="dt-stat-card__label">Ròng</div></div>
                </div>

                <t t-if="tab == 'activity'">
                    <div class="dt-list">
                        <t t-if="entries">
                            <t t-foreach="entries" t-as="entry">
                                <div class="dt-entry-row">
                                    <div class="dt-entry-head">
                                        <div>
                                            <div class="dt-entry-title"><t t-esc="entry.get_icon()"/> <t t-esc="entry.name or entry.category_id.name or entry.get_entry_type_label()"/></div>
                                            <div class="dt-entry-meta">
                                                <span class="dt-tag"><t t-esc="entry.expense_date.strftime('%d/%m/%Y') if entry.expense_date else ''"/></span>
                                                <span class="dt-tag" t-if="entry.category_id"><t t-esc="entry.category_id.name"/></span>
                                                <span class="dt-tag" t-if="scope == 'family'"><t t-esc="entry.user_id.name"/></span>
                                            </div>
                                            <div t-if="entry.note" class="dt-entry-note mt-1"><t t-esc="entry.note"/></div>
                                        </div>
                                        <div class="dt-inline-actions">
                                            <div t-attf-class="dt-entry-amount #{entry.amount_css_class}"><t t-esc="entry.amount_label"/></div>
                                            <details t-if="entry.user_id == request.env.user" class="dt-more-menu">
                                                <summary>⋮</summary>
                                                <div class="dt-more-menu__panel">
                                                    <a t-att-href="'/my/apps/expenses/%s/edit' % entry.id">Sửa</a>
                                                    <form t-att-action="'/my/apps/expenses/%s/delete' % entry.id" method="post">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <button type="submit">Xóa</button>
                                                    </form>
                                                </div>
                                            </details>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else=""><div class="dt-empty-state">Không có giao dịch khớp bộ lọc.</div></t>
                    </div>
                    <t t-if="simple_pager and simple_pager.get('page_count') &gt; 1">
                        <div class="dt-inline-actions mt-3">
                            <a t-if="simple_pager.get('prev_url')" t-att-href="simple_pager.get('prev_url')" class="dt-btn dt-btn--ghost">← Trước</a>
                            <t t-foreach="simple_pager.get('pages')" t-as="p">
                                <a t-att-href="p.get('url')" t-attf-class="dt-btn #{'dt-btn--primary' if p.get('is_current') else 'dt-btn--ghost'}"><t t-esc="p.get('number')"/></a>
                            </t>
                            <a t-if="simple_pager.get('next_url')" t-att-href="simple_pager.get('next_url')" class="dt-btn dt-btn--ghost">Sau →</a>
                        </div>
                    </t>
                </t>
                <t t-else="">
                    <div class="dt-card p-3">
                        <div class="dt-entry-head">
                            <div><div class="dt-section-title">Biểu đồ tròn</div></div>
                        </div>
                        <div class="dt-pie-wrap mt-3">
                            <div class="dt-pie-chart" t-att-style="statistics['pie_style']"></div>
                        </div>
                        <div class="dt-list mt-3">
                            <t t-if="statistics['rows']">
                                <t t-foreach="statistics['rows']" t-as="row">
                                    <div class="dt-report-row">
                                        <div class="dt-entry-head">
                                            <div class="dt-entry-title"><span class="dt-color-dot" t-att-style="'background:%s;' % row['color']"></span> <t t-esc="row['label']"/></div>
                                            <div class="dt-entry-note"><t t-esc="row['ratio']"/>%</div>
                                        </div>
                                        <div class="dt-entry-note"><t t-esc="row['amount']"/></div>
                                    </div>
                                </t>
                            </t>
                            <t t-else=""><div class="dt-empty-state">Chưa có dữ liệu để thống kê.</div></t>
                        </div>
                    </div>
                </t>
                <a href="/my/apps/expenses/new" class="dt-fab" aria-label="Tạo giao dịch">+</a>
            </section>
        </t>
    </template>
</odoo>
