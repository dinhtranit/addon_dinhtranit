<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_shell" name="Family Portal Shell">
        <t t-call="website.layout">
            <t t-set="no_footer" t-value="1"/>
            <div class="dt-shell" t-att-data-page="page_name or 'expenses'">
                <header class="dt-topbar">
                    <a t-if="back_url" t-att-href="back_url" class="dt-back-btn" aria-label="Quay lại">←</a>
                    <div class="dt-topbar__center">
                        <div class="dt-page-title"><t t-esc="page_title or 'Family'"/></div>
                        <div t-if="page_subtitle" class="dt-page-subtitle"><t t-esc="page_subtitle"/></div>
                    </div>
                    <a href="/my/profile" class="dt-avatar-link" aria-label="Trang cá nhân">
                        <img t-attf-src="/web/image/res.partner/#{request.env.user.partner_id.id}/avatar_128" alt="avatar"/>
                    </a>
                </header>
                <main class="dt-main-content"><t t-out="0"/></main>
                <nav class="dt-bottom-nav">
                    <a href="/my/apps/expenses" t-attf-class="dt-bottom-nav__item #{'is-active' if page_name == 'expenses' else ''}"><span>💸</span><small>Tài chính</small></a>
                    <a href="/my/apps/memories" t-attf-class="dt-bottom-nav__item #{'is-active' if page_name == 'memories' else ''}"><span>🕒</span><small>Memories</small></a>
                    <a href="/my/profile" t-attf-class="dt-bottom-nav__item #{'is-active' if page_name == 'profile' else ''}"><span>👤</span><small>Tôi</small></a>
                </nav>
            </div>
        </t>
    </template>

    <template id="portal_profile" name="Family Profile">
        <t t-call="dt_core.portal_shell">
            <section class="dt-section">
                <div class="dt-profile-card">
                    <div class="dt-profile-card__head">
                        <img t-attf-src="/web/image/res.partner/#{profile_partner.id}/avatar_128" alt="avatar" class="dt-profile-card__avatar"/>
                        <div>
                            <div class="dt-profile-card__name"><t t-esc="profile_partner.name"/></div>
                            <div class="dt-profile-card__meta">Mã thành viên: <strong><t t-esc="profile_partner.dt_member_code or '-'"/></strong></div>
                        </div>
                    </div>
                    <form action="/my/profile/save" method="post" enctype="multipart/form-data" class="dt-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label class="dt-field"><span>Đổi ảnh đại diện</span><input type="file" name="avatar_file" accept="image/*"/><div class="dt-file-help">Avatar mới sẽ hiển thị ở thanh trên và hồ sơ.</div></label>
                        <label class="dt-field"><span>Họ tên</span><input type="text" name="name" t-att-value="profile_partner.name or ''" required="required"/></label>
                        <label class="dt-field"><span>Số điện thoại</span><input type="text" name="phone" t-att-value="profile_partner.phone or ''"/></label>
                        <label class="dt-field"><span>Giới thiệu ngắn</span><textarea name="bio" rows="4"><t t-esc="profile_partner.dt_bio or ''"/></textarea></label>

                        <div class="dt-card p-3">
                            <div class="dt-section-title">Cấu hình gia đình</div>
                            <div class="dt-entry-note">Bạn quyết định ai được xem thu chi hoặc memories của mình. Người được bật quyền sẽ thấy dữ liệu của bạn trong chế độ Gia đình.</div>
                            <div class="dt-list mt-3">
                                <t t-if="family_users">
                                    <t t-foreach="family_users" t-as="member">
                                        <t t-set="member_access" t-value="access_map.get(member.id)"/>
                                        <div class="dt-entry-row">
                                            <div class="dt-entry-head">
                                                <div>
                                                    <div class="dt-entry-title"><t t-esc="member.name"/></div>
                                                    <div class="dt-entry-note"><t t-esc="member.login or ''"/></div>
                                                </div>
                                            </div>
                                            <div class="dt-inline-check-grid mt-2">
                                                <label class="dt-check-pill"><input type="checkbox" t-att-name="'family_expense_%s' % member.id" t-att-checked="'checked' if member_access and member_access.allow_expense else None"/> Cho xem thu chi</label>
                                                <label class="dt-check-pill"><input type="checkbox" t-att-name="'family_memory_%s' % member.id" t-att-checked="'checked' if member_access and member_access.allow_memory else None"/> Cho xem memories</label>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                                <t t-else=""><div class="dt-empty-state">Chưa có thành viên nào khác để cấu hình.</div></t>
                            </div>
                        </div>

                        <div class="dt-action-stack">
                            <button type="submit" class="dt-btn dt-btn--primary">Lưu thông tin</button>
                            <a href="/my/profile/logout" class="dt-btn dt-btn--ghost">Đăng xuất</a>
                        </div>
                    </form>
                </div>
            </section>
        </t>
    </template>
</odoo>
