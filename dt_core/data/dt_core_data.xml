<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_dt_partner_member_code" model="ir.sequence">
        <field name="name">DT Partner Member Code</field>
        <field name="code">dt.partner.member.code</field>
        <field name="prefix">U</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
    </record>

    <record id="seq_dt_media_code" model="ir.sequence">
        <field name="name">DT Media Code</field>
        <field name="code">dt.media.code</field>
        <field name="prefix">DTMED-%(year)s%(month)s%(day)s-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>
</odoo>
