<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<template id="portal_memories_feed" name="Family Memories Feed">
		<t t-call="dt_core.portal_shell">
			<a href="/my/apps/memories/new" class="dt-fab" aria-label="Tạo memory">+</a>
			<section class="dt-section">
				<div class="dt-hero-note">
					<strong>
						<t t-esc="total or 0"/>
					</strong> memory có thể xem • avatar góc phải dẫn tới trang cá nhân và memory của tôi.
				</div>
				<form method="get" action="/my/apps/memories" class="dt-form dt-card p-3">
					<label class="dt-field">
						<span>Tìm theo tiêu đề</span>
						<input type="text" name="search" t-att-value="search or ''" placeholder="Ví dụ: sinh nhật, Đà Lạt..."/>
					</label>
					<label class="dt-field">
						<span>Danh mục</span>
						<select name="category">
							<option value="">Tất cả</option>
							<t t-foreach="categories" t-as="cat">
								<option t-att-value="cat[0]" t-att-selected="'selected' if category == cat[0] else None">
									<t t-esc="cat[1]"/>
								</option>
							</t>
						</select>
					</label>
					<label class="dt-field">
						<span>Chế độ xem</span>
						<select name="mine">
							<option value="">Timeline chung</option>
							<option value="1" t-att-selected="'selected' if mine else None">Chỉ bài của tôi</option>
						</select>
					</label>
					<button type="submit" class="dt-btn dt-btn--secondary">Lọc timeline</button>
				</form>
				<t t-if="diaries">
					<div class="dt-list">
						<t t-foreach="diaries" t-as="diary">
							<a t-att-href="'/my/apps/memories/%s' % diary.id" class="dt-memory-card">
								<t t-if="diary.cover_media_id">
									<div class="dt-cover">
										<t t-if="diary.cover_media_id.media_type == 'image'">
											<img t-att-src="diary.cover_media_id.image_url()" alt="cover"/>
										</t>
										<t t-elif="diary.cover_media_id.media_type == 'video'">
											<video muted="muted" playsinline="playsinline" preload="metadata">
												<source t-att-src="diary.cover_media_id.stream_url()" t-att-type="diary.cover_media_id.mimetype or 'video/mp4'"/>
											</video>
										</t>
									</div>
								</t>
								<div class="dt-memory-card__head">
									<div>
										<div class="dt-memory-card__title">
											<t t-esc="diary.title"/>
										</div>
										<div class="dt-text-muted">
											<t t-esc="diary.partner_id.name"/> • 
											<t t-esc="diary.memory_date.strftime('%d/%m/%Y') if diary.memory_date else ''"/>
										</div>
									</div>
									<div class="dt-tag">
										<t t-esc="diary.get_emotion_icon()"/>
									</div>
								</div>
								<div class="dt-memory-meta">
									<span class="dt-tag">
										<t t-esc="dict(diary._fields['category'].selection).get(diary.category, diary.category or '')"/>
									</span>
									<span class="dt-tag">📷 
										<t t-esc="diary.image_count"/>
									</span>
									<span class="dt-tag">🎥 
										<t t-esc="diary.video_count"/>
									</span>
									<span class="dt-tag">👁️ 
										<t t-esc="diary.view_count"/>
									</span>
								</div>
								<div t-if="diary.location" class="dt-text-muted">📍 
									<t t-esc="diary.location"/>
								</div>
							</a>
						</t>
					</div>
				</t>
				<t t-else="">
					<div class="dt-empty-state">
						<div class="dt-section-title">Chưa có memory phù hợp</div>
						<div class="dt-text-muted">Bạn có thể tạo mới ngay từ nút cộng nổi.</div>
					</div>
				</t>
				<t t-if="pager and pager.get('page_count', 0) &gt; 1">
					<div class="o_portal_pager">
						<t t-call="portal.portal_pager"/>
					</div>
				</t>
			</section>
		</t>
	</template>
	<template id="portal_memory_detail" name="Family Memory Detail">
		<t t-call="dt_core.portal_shell">
			<section class="dt-section">
				<div class="dt-memory-detail">
					<div class="dt-detail-head">
						<div>
							<div class="dt-memory-card__title">
								<t t-esc="diary.title"/>
							</div>
							<div class="dt-text-muted">
								<t t-esc="diary.partner_id.name"/> • 
								<t t-esc="diary.memory_date.strftime('%d/%m/%Y') if diary.memory_date else ''"/>
							</div>
						</div>
						<div class="dt-tag">
							<t t-esc="diary.get_emotion_icon()"/>
						</div>
					</div>
					<div class="dt-memory-meta">
						<span class="dt-tag">#
							<t t-esc="diary.code"/>
						</span>
						<span class="dt-tag">
							<t t-esc="dict(diary._fields['privacy'].selection).get(diary.privacy, diary.privacy or '')"/>
						</span>
						<span t-if="diary.location" class="dt-tag">📍 
							<t t-esc="diary.location"/>
						</span>
					</div>
					<div t-if="diary.story">
						<t t-raw="diary.story"/>
					</div>
				</div>
				<t t-set="media_items" t-value="diary.get_media_items()"/>
				<t t-if="media_items">
					<div class="dt-media-grid">
						<t t-foreach="media_items" t-as="media">
							<div class="dt-media-tile">
								<t t-if="media.media_type == 'image'">
									<a t-att-href="media.stream_url()">
										<img t-att-src="media.image_url()" alt="media"/>
									</a>
								</t>
								<t t-elif="media.media_type == 'video'">
									<video controls="controls" playsinline="playsinline" preload="metadata">
										<source t-att-src="media.stream_url()" t-att-type="media.mimetype or 'video/mp4'"/>
									</video>
								</t>
							</div>
						</t>
					</div>
				</t>
				<div t-if="diary.user_id == request.env.user" class="dt-top-actions">
					<a t-att-href="'/my/apps/memories/%s/edit' % diary.id" class="dt-btn dt-btn--secondary">Sửa memory</a>
					<form t-att-action="'/my/apps/memories/%s/delete' % diary.id" method="post">
						<input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
						<button type="submit" class="dt-btn dt-btn--ghost">Xóa</button>
					</form>
				</div>
			</section>
		</t>
	</template>
	<template id="portal_memory_form" name="Family Memory Form">
		<t t-call="dt_core.portal_shell">
			<section class="dt-section">
				<form action="/my/apps/memories/save" method="post" enctype="multipart/form-data" class="dt-form dt-card p-3">
					<input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
					<input t-if="diary" type="hidden" name="diary_id" t-att-value="diary.id"/>
					<label class="dt-field">
						<span>Tiêu đề</span>
						<input type="text" name="title" required="required" placeholder="Ví dụ: Sinh nhật bé Bin" t-att-value="diary.title if diary else ''"/>
					</label>
					<label class="dt-field">
						<span>Ngày</span>
						<input type="date" name="memory_date" t-att-value="default_date"/>
					</label>
					<label class="dt-field">
						<span>Địa điểm</span>
						<input type="text" name="location" t-att-value="diary.location if diary else ''" placeholder="Ví dụ: Đà Lạt, ở nhà, trường học..."/>
					</label>
					<label class="dt-field">
						<span>Cảm xúc</span>
						<select name="emotion">
							<t t-foreach="request.env['dt.memoire.diary']._fields['emotion'].selection" t-as="emotion_item">
								<option t-att-value="emotion_item[0]" t-att-selected="'selected' if diary and diary.emotion == emotion_item[0] else ('selected' if (not diary and emotion_item[0] == 'joyful') else None)">
									<t t-esc="emotion_item[1]"/>
								</option>
							</t>
						</select>
					</label>
					<label class="dt-field">
						<span>Danh mục</span>
						<select name="category">
							<t t-foreach="request.env['dt.memoire.diary']._fields['category'].selection" t-as="category_item">
								<option t-att-value="category_item[0]" t-att-selected="'selected' if diary and diary.category == category_item[0] else ('selected' if (not diary and category_item[0] == 'daily') else None)">
									<t t-esc="category_item[1]"/>
								</option>
							</t>
						</select>
					</label>
					<label class="dt-field">
						<span>Chia sẻ với</span>
						<select name="privacy">
							<t t-foreach="request.env['dt.memoire.diary']._fields['privacy'].selection" t-as="privacy_item">
								<option t-att-value="privacy_item[0]" t-att-selected="'selected' if diary and diary.privacy == privacy_item[0] else ('selected' if (not diary and privacy_item[0] == 'family') else None)">
									<t t-esc="privacy_item[1]"/>
								</option>
							</t>
						</select>
					</label>
					<label class="dt-field">
						<span>Album</span>
						<select name="album_id">
							<option value="0">Không chọn</option>
							<t t-foreach="albums" t-as="album">
								<option t-att-value="album.id" t-att-selected="'selected' if diary and diary.album_id and diary.album_id.id == album.id else None">
									<t t-esc="album.name"/>
								</option>
							</t>
						</select>
					</label>
					<label class="dt-field">
						<span>Thẻ</span>
						<select name="tag_ids" multiple="multiple">
							<t t-foreach="tags" t-as="tag">
								<option t-att-value="tag.id" t-att-selected="'selected' if diary and tag in diary.tag_ids else None">
									<t t-esc="tag.name"/>
								</option>
							</t>
						</select>
						<div class="dt-file-help">Trên mobile có thể bỏ qua phần này nếu chỉ cần tạo nhanh.</div>
					</label>
					<label class="dt-field">
						<span>Câu chuyện</span>
						<textarea name="story" rows="6" placeholder="Viết lại điều muốn nhớ về ngày này...">
							<t t-esc="diary.story if diary else ''"/>
						</textarea>
					</label>
					<label class="dt-field">
						<span>Ảnh và video</span>
						<input type="file" name="media_files" multiple="multiple" accept="image/*,video/*"/>
						<div class="dt-file-help">Có thể chọn nhiều ảnh và video cùng lúc. File đầu tiên sẽ được dùng làm cover khi record chưa có media.</div>
					</label>
					<button type="submit" class="dt-btn dt-btn--primary">Lưu memory</button>
				</form>
				<t t-if="diary and diary.get_media_items()">
					<div class="dt-card">
						<div class="dt-section-title">Media hiện có</div>
						<div class="dt-media-grid">
							<t t-foreach="diary.get_media_items()" t-as="media">
								<div class="dt-media-tile">
									<t t-if="media.media_type == 'image'">
										<img t-att-src="media.image_url()" alt="media"/>
									</t>
									<t t-else="">
										<video playsinline="playsinline" preload="metadata">
											<source t-att-src="media.stream_url()" t-att-type="media.mimetype or 'video/mp4'"/>
										</video>
									</t>
									<form t-att-action="'/my/apps/memories/media/%s/delete' % media.id" method="post" class="position-absolute" style="top:8px;right:8px;">
										<input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
										<input type="hidden" name="diary_id" t-att-value="diary.id"/>
										<button type="submit" class="dt-btn dt-btn--ghost" style="padding:6px 10px;">✕</button>
									</form>
								</div>
							</t>
						</div>
					</div>
				</t>
			</section>
		</t>
	</template>
</odoo>
